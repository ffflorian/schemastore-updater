{
  "bin": "./dist/cli.js",
  "dependencies": {
    "commander": "14.0.3",
    "date-fns": "4.1.0",
    "json-schema-to-typescript": "15.0.4",
    "semver": "7.7.4",
    "typescript": "6.0.2"
  },
  "description": "SchemaStore schema updater",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@ffflorian/eslint-config": "0.13.7",
    "@ffflorian/prettier-config": "0.6.7",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@types/node": "~24",
    "@types/semver": "7.7.1",
    "eslint": "10.1.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-oxlint": "1.57.0",
    "eslint-plugin-perfectionist": "5.7.0",
    "lefthook": "2.1.4",
    "oxlint": "1.57.0",
    "prettier": "3.8.1",
    "semantic-release": "25.0.3",
    "tsx": "4.21.0",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "GPL-3.0",
  "name": "schemastore-updater",
  "packageManager": "yarn@4.13.0",
  "prettier": "@ffflorian/prettier-config",
  "private": true,
  "repository": "https://github.com/ffflorian/schemastore-updater",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist schemas schema-lock.json .cache",
    "fix": "yarn fix:ts && yarn fix:other",
    "fix:other": "yarn prettier --write",
    "fix:ts": "yarn lint:ts:oxlint --fix && yarn lint:ts:eslint --fix",
    "lint": "yarn lint:other && yarn lint:ts",
    "lint:other": "yarn prettier --list-different",
    "lint:ts": "yarn lint:ts:oxlint && yarn lint:ts:eslint",
    "lint:ts:eslint": "eslint src",
    "lint:ts:oxlint": "oxlint --ignore-path .gitignore .",
    "publish:schemas": "tsx src/cli.ts publish",
    "publish:schemas:dry-run": "tsx src/cli.ts publish --dry-run",
    "prettier": "prettier \"*.{json,md,yml}\"",
    "release": "semantic-release",
    "test": "vitest run",
    "test:watch": "vitest",
    "update": "tsx src/cli.ts update"
  },
  "type": "module",
  "version": "3.0.0"
}
